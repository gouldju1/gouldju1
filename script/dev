#!/bin/sh
# dev — install dependencies and serve the site locally
# Usage: ./script/dev

set -e

cd "$(dirname "$0")/.."

# Check Ruby
if ! command -v ruby >/dev/null 2>&1; then
  echo "Ruby not found. Install it with: brew install ruby"
  exit 1
fi

# Check Bundler, install if missing
if ! command -v bundle >/dev/null 2>&1; then
  echo "Installing Bundler..."
  gem install bundler
fi

# Install / sync gems into local vendor/bundle (no sudo needed)
echo "Installing gems..."
bundle install --path vendor/bundle

# Serve with live reload
echo ""
echo "Starting Jekyll server at http://localhost:4000/gouldju1/"
echo "Press Ctrl+C to stop."
echo ""
bundle exec jekyll serve --livereload
